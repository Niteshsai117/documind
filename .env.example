# Copy this file to .env to override any of these defaults.
# No API key is required — DocuMind uses a local Ollama model.
#
# Before running the app:
#   1. Install Ollama: https://ollama.com/download
#   2. Pull the model: ollama pull llama3
#   3. Make sure the Ollama server is running (it starts automatically on
#      most installs, or run `ollama serve`).

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_MAX_TOKENS=1024

EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

CHUNK_SIZE=500
CHUNK_OVERLAP=50

CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=documind

RETRIEVAL_TOP_K=5
RERANK_TOP_N=3

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=25
